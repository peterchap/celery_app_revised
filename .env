DNS_NAMESERVERS=127.0.0.1
#DNS_NAMESERVERS=1.1.1.1,8.8.8.8
DNS_COLLECT_SRV=always
#DNS_COLLECT_SRV=new_only
DEFAULT_QPS_LIMIT=600
DEFAULT_SEMAPHORE_LIMIT=512
DNS_SEMAPHORE_LIMIT=512
DNS_BATCH_WORKERS=256
DNS_TIMEOUT=3
DNS_LIFETIME=5
DNS_LOG_DIR=logs
DNS_LMDB_PTR_DIR=/mnt/shared/dns_lmdb_ptr
LMDB_DIR=/mnt/shared/dns_lmdb
LOOKUPS_DB_PATH=/mnt/shared/lookups/
ENABLE_INTERLEAVED=true
USE_CHUNKED_PROCESSING=true
DNS_CACHE_TXT = "0"
DNS_BYPASS_NEGATIVE_CACHE = "1" 
